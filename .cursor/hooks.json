{
    "version": 1,
    "hooks": {
      "afterFileEdit": [
        {
          "command": "powershell.exe -NoProfile -NonInteractive -WindowStyle Hidden -ExecutionPolicy Bypass -File .\\.cursor\\hooks\\sync-types.ps1"
        },
        {
          "command": "powershell.exe -NoProfile -NonInteractive -WindowStyle Hidden -ExecutionPolicy Bypass -File .\\.cursor\\hooks\\run-tests.ps1"
        },
        {
          "command": "powershell.exe -NoProfile -NonInteractive -WindowStyle Hidden -ExecutionPolicy Bypass -File .\\.cursor\\hooks\\strict-type-check.ps1"
        },
        {
          "command": "pythonw .\\.cursor\\hooks\\architecture-guard.py"
        }
      ],
      "beforeReadFile": [
        {
          "command": "powershell.exe -NoProfile -NonInteractive -WindowStyle Hidden -ExecutionPolicy Bypass -File .\\.cursor\\hooks\\guard-migrations.ps1"
        },
        {
          "command": "pythonw .\\.cursor\\hooks\\component-check.py"
        }
      ],
      "beforeSubmitPrompt": [
        {
          "command": "pythonw .\\.cursor\\hooks\\secret-guardian.py"
        },
        {
          "command": "pythonw .\\.cursor\\hooks\\architecture-guard.py"
        }
      ],
      "beforeShellExecution": [
        {
          "command": "pythonw .\\.cursor\\hooks\\secret-guardian.py"
        }
      ],
      "stop": [
        {
          "command": "powershell.exe -NoProfile -NonInteractive -WindowStyle Hidden -ExecutionPolicy Bypass -File .\\.cursor\\hooks\\changelog-stop.ps1",
          "loop_limit": 2
        }
      ]
    }
  }
