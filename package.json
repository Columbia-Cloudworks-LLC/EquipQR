{
  "name": "equipqr",
  "private": true,
  "version": "3.8.0",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "overrides": {
    "vite": "^8.0.13",
    "esbuild": "^0.25.0",
    "node-domexception": "^1.0.0",
    "tar": "7.5.11",
    "serialize-javascript": "^7.0.5"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsx scripts/generate-sitemap.ts && vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "verify:preview-access": "node scripts/verify-preview-access.mjs",
    "verify:spa-routing": "node scripts/verify-spa-shell.mjs",
    "verify:node-policy": "node scripts/verify-node-policy.mjs",
    "test": "node scripts/test-runner.mjs",
    "test:itil-scripts": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/itil/tests/Run-ItilWorkflowTests.ps1",
    "test:coverage": "node scripts/test-runner.mjs --coverage",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:journeys": "node scripts/test-runner.mjs src/tests/journeys",
    "test:e2e": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/run-user-regression.ps1 -Suite critical -Headless",
    "test:e2e:critical": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/run-user-regression.ps1 -Suite critical -Headless",
    "test:e2e:full": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/run-user-regression.ps1 -Suite full -Headless",
    "test:e2e:headed": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/run-user-regression.ps1 -Suite critical -Headed",
    "test:e2e:watch": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/run-user-regression.ps1 -Suite critical -Watch",
    "test:e2e:record": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/run-user-regression.ps1 -Suite critical -RecordVideo",
    "test:db": "supabase test db",
    "db:start": "supabase start",
    "test:ci": "npm run test:coverage && node scripts/coverage-ratchet.mjs",
    "test:shard": "node scripts/test-ci-shard.mjs",
    "coverage:merge": "node scripts/merge-coverage.mjs",
    "analyze": "npm run build && npx vite-bundle-analyzer",
    "size-check": "npx size-limit",
    "type-check": "tsc --noEmit",
    "deploy:vercel": "npx --yes vercel@51.6.1 --prod",
    "docs:dev": "npm --prefix docs run docs:dev",
    "docs:build": "npm --prefix docs run docs:build",
    "docs:preview": "npm --prefix docs run docs:preview",
    "deploy:netlify": "netlify deploy --prod",
    "generate:vapid-keys": "node scripts/generate-vapid-keys.mjs",
    "generate:large-inventory": "npx tsx scripts/generate-large-inventory-seed.ts > supabase/seeds/26_large_inventory.sql",
    "demo:gif": "node scripts/demo-gif.mjs",
    "demo:video-smoke": "node scripts/demo-gif.mjs --smoke",
    "demo:video-smoke:reliability": "node scripts/repeat-demo-smoke.mjs",
    "demo:record:preflight": "node scripts/demo-record-preflight.mjs",
    "demo:record:preflight:prod": "node scripts/demo-record-preflight.mjs --require-storage-state",
    "demo:record": "npm run demo:record:preflight && node scripts/demo-record-finalize.mjs --flow=demo-record",
    "demo:record:prod": "npm run demo:record:preflight:prod && node scripts/demo-record-finalize.mjs --flow=demo-prod",
    "demo:record:prod:reliability": "node scripts/repeat-demo-record-prod.mjs",
    "demo:v2:list": "node scripts/demo-record-v2.mjs list",
    "demo:v2:run": "node scripts/demo-record-v2.mjs run --scenario=executive-overview",
    "demo:v2:run:prod": "node scripts/demo-record-v2.mjs run --scenario=executive-overview --prod",
    "demo:v2:suite": "node scripts/demo-record-v2.mjs suite --suite=core",
    "demo:v2:reliability:scenario": "node scripts/demo-record-v2.mjs reliability --scenario=executive-overview --runs=3",
    "demo:v2:reliability:suite": "node scripts/demo-record-v2.mjs reliability --suite=core --runs=2",
    "demo:v2:compose:on": "node scripts/demo-record-v2.mjs run --scenario=executive-overview --compose-scenes --capture-scene-clips",
    "demo:v2:compose:off": "node scripts/demo-record-v2.mjs run --scenario=executive-overview --no-compose-scenes",
    "demo:v2:dry-run": "node scripts/demo-record-v2.mjs suite --suite=core --dry-run",
    "generate:state-vectors": "node scripts/generate-state-vectors.mjs"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "5.2.8",
