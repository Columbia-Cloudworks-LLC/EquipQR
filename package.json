{
  "name": "equipqr",
  "private": true,
  "version": "3.26.1",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "overrides": {
    "vite": "^8.0.13",
    "esbuild": "^0.25.0",
    "node-domexception": "^1.0.0",
    "tar": "7.5.11",
    "serialize-javascript": "^7.0.5"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsx scripts/generate-sitemap.ts && vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "lint:md": "markdownlint-cli2 \".cursor/**/*.{md,mdc}\" \"AGENTS.md\"",
    "preview": "vite preview",
    "verify:preview-access": "node scripts/verify-preview-access.mjs",
    "verify:spa-routing": "node scripts/verify-spa-shell.mjs",
    "verify:node-policy": "node scripts/verify-node-policy.mjs",
    "verify:release-metadata": "node scripts/verify-release-metadata.mjs",
    "verify:schema-reference": "node scripts/check-schema-reference.mjs",
    "test": "node scripts/run-vitest-local.mjs",
    "test:itil-scripts": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/itil/tests/Run-ItilWorkflowTests.ps1",
    "test:unit": "node scripts/run-vitest-local.mjs --project unit",
    "test:component": "node scripts/run-vitest-local.mjs --project component",
    "test:coverage": "node scripts/run-vitest-local.mjs --coverage",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:e2e": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/run-user-regression.ps1 -Suite critical -Headless",
    "test:e2e:critical": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/run-user-regression.ps1 -Suite critical -Headless",
    "test:e2e:full": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/run-user-regression.ps1 -Suite full -Headless",
    "test:e2e:local-full": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/run-user-regression.ps1 -Suite all -Headless -ResetDb",
    "test:e2e:mobile-critical": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/run-user-regression.ps1 -Suite critical -Headless -ViewportMode mobile",
    "test:e2e:both-critical": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/run-user-regression.ps1 -Suite critical -Headless -ViewportMode both",
    "test:e2e:headed": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/run-user-regression.ps1 -Suite critical -Headed",
    "test:e2e:watch": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/run-user-regression.ps1 -Suite critical -Watch",
    "test:e2e:record": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/run-user-regression.ps1 -Suite critical -RecordVideo",
    "test:e2e:demo": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/run-user-regression.ps1 -Suite critical -RunProfile demo",
    "test:db": "supabase test db",
    "db:migration:new": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/db/New-SupabaseMigration.ps1",
    "db:rpc-inventory": "node scripts/generate-security-definer-rpc-inventory.mjs",
    "verify:rpc-allowlists": "node scripts/validate-security-definer-allowlist-sync.mjs",
    "fallow:scan": "npx --yes fallow@2.88.0 dead-code --format json --quiet",
    "fallow:audit": "npx --yes fallow@2.88.0 audit --base origin/main --gate new-only --format json --quiet",
    "fallow:dupes": "npx --yes fallow@2.88.0 dupes --format json --quiet",
    "fallow:health": "npx --yes fallow@2.88.0 health --score --hotspots --targets --format json --quiet",
    "fallow:fix:preview": "npx --yes fallow@2.88.0 fix --dry-run --format json --quiet",
    "db:start": "supabase start",
    "test:ci": "node scripts/test-ci-entry.mjs",
    "test:ci:sharded": "node scripts/test-ci-sharded.mjs --shards=4",
    "test:shard": "node scripts/test-ci-shard.mjs",
    "test:perf:report": "node scripts/vitest-perf/report-vitest-durations.mjs",
    "test:perf:publish-comment": "node scripts/vitest-perf/publish-duration-pr-comment.mjs",
    "coverage:merge": "node scripts/merge-coverage.mjs",
    "analyze": "npm run build && npx vite-bundle-analyzer",
    "size-check": "npx size-limit",
    "type-check": "tsc --noEmit",
    "ci:install": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/Invoke-SafeNpmCi.ps1",
    "deploy:vercel": "npx --yes vercel@51.6.1 --prod",
    "docs:dev": "npm --prefix docs run docs:dev",
    "docs:build": "npm --prefix docs run docs:build",
    "docs:preview": "npm --prefix docs run docs:preview",
    "deploy:netlify": "netlify deploy --prod",
    "generate:vapid-keys": "node scripts/generate-vapid-keys.mjs",
    "seed:generate": "tsx scripts/seed-data/generate-seeds.ts",
    "demo:gif": "node scripts/demo-gif.mjs",
    "demo:video-smoke": "node scripts/demo-gif.mjs --smoke",
    "demo:video-smoke:reliability": "node scripts/repeat-demo-smoke.mjs",
    "demo:record:preflight": "node scripts/demo-record-preflight.mjs",
    "demo:record:preflight:prod": "node scripts/demo-record-preflight.mjs --require-storage-state",
    "demo:record": "npm run demo:record:preflight && node scripts/demo-record-finalize.mjs --flow=demo-record",
    "demo:record:prod": "npm run demo:record:preflight:prod && node scripts/demo-record-finalize.mjs --flow=demo-prod",
    "demo:record:prod:reliability": "node scripts/repeat-demo-record-prod.mjs",
    "demo:v2:list": "node scripts/demo-record-v2.mjs list",
    "demo:v2:run": "node scripts/demo-record-v2.mjs run --scenario=executive-overview",
    "demo:v2:run:prod": "node scripts/demo-record-v2.mjs run --scenario=executive-overview --prod",
    "demo:v2:suite": "node scripts/demo-record-v2.mjs suite --suite=core",
    "demo:v2:reliability:scenario": "node scripts/demo-record-v2.mjs reliability --scenario=executive-overview --runs=3",
    "demo:v2:reliability:suite": "node scripts/demo-record-v2.mjs reliability --suite=core --runs=2",
    "demo:v2:compose:on": "node scripts/demo-record-v2.mjs run --scenario=executive-overview --compose-scenes --capture-scene-clips",
    "demo:v2:compose:off": "node scripts/demo-record-v2.mjs run --scenario=executive-overview --no-compose-scenes",
    "demo:v2:dry-run": "node scripts/demo-record-v2.mjs suite --suite=core --dry-run",
    "pr-evidence:capture": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/pr-evidence/Invoke-PrEvidenceCapture.ps1",
    "pr-evidence:publish": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/pr-evidence/Publish-PrEvidence.ps1",
    "pr-evidence": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/pr-evidence/Invoke-PrEvidence.ps1",
    "upload-github-asset": "tsx scripts/upload-github-asset.ts",
    "e2e:google-auth:capture": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"$env:E2E_REAL_AUTH_BASE_URL='http://localhost:8080'; npx playwright test --config=playwright.google-auth-setup.config.ts --headed\"",
    "e2e:quickbooks-auth:capture": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"$env:E2E_REAL_AUTH_BASE_URL='http://localhost:8080'; npx playwright test --config=playwright.quickbooks-auth-setup.config.ts --headed\"",
    "e2e:quickbooks-developer-auth:capture": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"npx playwright test --config=playwright.quickbooks-developer-auth-setup.config.ts --headed\"",
    "generate:state-vectors": "node scripts/generate-state-vectors.mjs"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "5.2.8",
