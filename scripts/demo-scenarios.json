        { "type": "action", "action": "fill", "selector": "input[name=title], input[id*=title], input[placeholder*=title i]", "value": "Lifecycle Demo Work Order" },
        { "type": "action", "action": "fill", "selector": "textarea[name=description], textarea[id*=description], textarea[placeholder*=description i]", "value": "Demonstrate baseline submitted work order flow." },
        { "type": "action", "action": "clickByText", "text": "Create Work Order|Save|Submit", "selector": "button,[data-testid='submit-button']" },
        { "type": "action", "action": "snapshot" }
      ]
    },
    {
      "name": "pm-checklist-on-work-order",
      "description": "Highlight PM checklist flow from work order creation with template selection.",
      "category": "work-orders",
      "audience": "tutorial",
      "viewport": "desktop",
      "tags": ["pm", "checklist", "maintenance"],
      "route": "/dashboard/work-orders",
      "steps": [
        { "type": "action", "action": "clickByText", "text": "Create Work Order", "selector": "button,[aria-label*='create work order' i]" },
        { "type": "action", "action": "fill", "selector": "input[name=title], input[id*=title], input[placeholder*=title i]", "value": "PM Checklist Demo WO" },
        { "type": "action", "action": "clickByText", "text": "With PM Checklist", "selector": "button,[role=radio]" },
        { "type": "playwright", "command": "playwright-cli eval \"() => { const trigger = document.querySelector('[id=pmTemplate], [id*=pmTemplate], [aria-label*=template i]'); if (trigger) { trigger.click(); const option = document.querySelector('[role=option]'); if (option) option.click(); } }\"" },
        { "type": "action", "action": "snapshot" }
      ]
    },
    {
      "name": "create-new-work-order-and-equipment-record",
      "description": "Create work order and inline-create equipment from the work-order form.",
      "category": "work-orders",
      "audience": "tutorial",
      "viewport": "desktop",
      "tags": ["inline-create", "work-order", "equipment"],
      "route": "/dashboard/work-orders",
      "steps": [
        { "type": "action", "action": "clickByText", "text": "Create Work Order", "selector": "button,[aria-label*='create work order' i]" },
        { "type": "action", "action": "fill", "selector": "input[name=title], input[id*=title], input[placeholder*=title i]", "value": "Demo WO with inline equipment" },
        { "type": "action", "action": "fill", "selector": "textarea[name=description], textarea[id*=description], textarea[placeholder*=description i]", "value": "Inline equipment creation demo." },
        { "type": "action", "action": "clickByText", "text": "Create New", "selector": "button,[role=tab]" },
        { "type": "action", "action": "fill", "selector": "input[id=manufacturer], input[name=manufacturer]", "value": "Komatsu" },
        { "type": "action", "action": "fill", "selector": "input[id=model], input[name=model]", "value": "PC210" },
        { "type": "action", "action": "fill", "selector": "input[id=serial_number], input[name=serial_number]", "value": "INLINE-DEMO-200" },
        { "type": "action", "action": "clickByText", "text": "Create Equipment", "selector": "button" },
        { "type": "action", "action": "clickByText", "text": "Create Work Order|Save|Submit", "selector": "button,[data-testid='submit-button']" },
        { "type": "action", "action": "snapshot" }
      ]
    },
    {
