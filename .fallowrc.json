{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "ignoreDependencies": [
    "size-limit",
    "@size-limit/file",
    "tailwindcss-animate",
    "us-atlas",
    "xlsx"
  ],
  "ignorePatterns": [
    "vitest/**"
  ],
  "ignoreExportsUsedInFile": true,
  "duplicates": {
    "ignore": [
      "src/integrations/supabase/types.ts",
      "src/pages/PrivacyPolicy.tsx",
      "src/pages/TermsOfService.tsx",
      "src/pages/features/**",
      "src/pages/solutions/**",
      "src/components/landing/**",
      "supabase/functions/**",
      "scripts/**",
      "e2e/**/*.ts",
      "src/**/*.test.ts",
      "src/**/*.test.tsx",
      "vitest/**",
      "scripts/**/*.test.ts",
      "scripts/**/*.test.mjs",
      "e2e/**/*.test.ts",
      "supabase/functions/**/*.test.ts",
      "supabase/functions/**/*.deno.test.ts",
      "supabase/functions/**/*.vitest.test.ts",
      ".github/scripts/**/*.test.js"
    ]
  },
  "entry": [
    "playwright.user.config.ts",
    "src/sw.ts",
    "scripts/check-main-branch-migrations.mjs",
    "scripts/check-missing-migrations.mjs",
    "scripts/create-missing-migrations.mjs",
    "scripts/fix-main-branch-migrations.mjs",
    "scripts/reconcile-advisor-rpc-warnings.mjs",
