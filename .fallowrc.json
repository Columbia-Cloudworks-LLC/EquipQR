    "scripts/test-ci.mjs",
    "scripts/test-ci-entry.mjs",
    "scripts/test-ci-sharded.mjs",
    "scripts/test-ci-windows.mjs",
    "scripts/upload-screenshot.ts",
    "scripts/docs-media/print-storage-path.ts",
    "scripts/run-vitest-local.test.mjs",
    "scripts/vitest-perf/report-vitest-durations.test.mjs"
  ],
  "ignoreExports": [
    {
      "file": "src/components/ui/**",
      "exports": ["*"]
    },
    {
