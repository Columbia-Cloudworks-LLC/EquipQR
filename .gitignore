#Ignore vscode AI rules
.github\instructions\codacy.instructions.md

# Agent ecosystems not used in this Cursor-only workspace
.agents/
.claude/
skills-lock.json

# Cursor hook runtime state (generated during chat sessions)
.cursor/hooks/state/

# Cursor agent session plans (ephemeral)
.cursor/plans/

# Python bytecode from local hook runs
.cursor/hooks/__pycache__/

# Firecrawl scrape/research output — local-only agent artifacts.
# Kept on disk for reference but never committed.
.firecrawl/
.fallow/

.vercel

# VitePress build artifacts — regenerated on every docs dev/build run.
docs/.vitepress/cache/
docs/.vitepress/.temp/

# Build artifact — regenerated by scripts/generate-sitemap.ts on every `npm run build`.
# Tracking it produces noisy PR diffs and breaks build reproducibility.
public/sitemap.xml

# Local-only dev helpers written by the demo-mobile-screenshot skill.
# These are mobile-emulation iframe wrappers used by the agent for screenshots
# and must never ship to production.
public/__mobile-frame.html
public/__viewport-probe.html

